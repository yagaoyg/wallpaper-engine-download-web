{
  "manifest_version": 3,
  "name": "WallHub System Proxy",
  "version": "1.0.0",
  "description": "通过浏览器网络栈访问 Steam 创意工坊，使用系统代理即可访问。",
  "action": {
    "default_title": "WallHub Proxy",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://steamcommunity.com/*",
    "https://api.steampowered.com/*"
  ]
}
